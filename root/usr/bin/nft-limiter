#!/bin/sh
# nft-limiter - pure nftables traffic shaping engine for OpenWrt 25.12+ / fw4
#
# Supported target formats:
#   Range : 192.168.1.1-192.168.1.200  -> ip daddr/saddr (nftables native)
#   CIDR  : 192.168.1.0/24             -> ip daddr/saddr
#   IP    : 192.168.1.50               -> ip daddr/saddr
#
# Interface scoping: rules match only on user-selected WAN/VPN interfaces
# (meta iifname for download, meta oifname for upload), so LAN-to-LAN
# traffic is never rate-limited.
#
# Commands: start | stop | add <idx> | del <idx> | status

. /lib/functions.sh

NAME="nft-limiter"
NFT_TABLE="fw4"
NFT_CHAIN="custom_qos_enforce"
NFT_FILE="/var/run/nft-limiter.nft"

_iface_set=""

# -----------------------------------------------------------------------
# _build_iface_set -- read UCI iface option, build nft set string
#   e.g. _iface_set becomes:  "wan", "wg0"
# -----------------------------------------------------------------------
_build_iface_set() {
    local ifaces i dev
    ifaces=$(uci -q get "${NAME}.@${NAME}[0].iface")
    [ -z "$ifaces" ] && ifaces="wan"
    _iface_set=""
    for i in $ifaces; do
        dev=$(ifstatus "$i" 2>/dev/null | jsonfilter -e '@.l3_device' 2>/dev/null)
        [ -z "$dev" ] && dev="$i"
        _iface_set="${_iface_set:+${_iface_set}, }\"${dev}\""
    done
}

# -----------------------------------------------------------------------
# _ip4_to_int <a.b.c.d> -- echo the 32-bit integer value, or return 1 if
#   the argument is not a dotted-quad IPv4 address.
# -----------------------------------------------------------------------
_ip4_to_int() {
    local ip="$1" a b c d o
    case "$ip" in
        *.*.*.*) ;;
        *) return 1 ;;
    esac
    a="${ip%%.*}"; ip="${ip#*.}"
    b="${ip%%.*}"; ip="${ip#*.}"
    c="${ip%%.*}"; ip="${ip#*.}"
    d="$ip"
    for o in "$a" "$b" "$c" "$d"; do
        case "$o" in ''|*[!0-9]*) return 1 ;; esac
        [ "$o" -le 255 ] || return 1
    done
    echo "$(( (a << 24) + (b << 16) + (c << 8) + d ))"
}

# -----------------------------------------------------------------------
# _target_addr_count <target> -- echo how many addresses the target covers.
#   Used as a specificity sort key: fewer addresses = more specific. So a
#   single host sorts before a subnet, and a tight subnet before a broad
#   one. This lets a per-host rule win over a subnet/range that contains
#   it, regardless of the order the devices appear in UCI (nftables is
#   first-match and the pass-through accept is terminal).
#     single host = 1 ; IPv4 CIDR = 2^(32-prefix) ; range = end-start+1.
#   IPv6 CIDR and anything unparseable fall back to a very large key
#   (treated as least specific, emitted last).
# -----------------------------------------------------------------------
_target_addr_count() {
    local t="$1" s e si ei pfx
    case "$t" in
        *-*)   # IPv4 range  start-end
            s="${t%%-*}"; e="${t##*-}"
            si=$(_ip4_to_int "$s") || { echo 4294967296; return; }
            ei=$(_ip4_to_int "$e") || { echo 4294967296; return; }
            [ "$ei" -ge "$si" ] && { echo "$(( ei - si + 1 ))"; return; }
            echo 4294967296 ;;
        */*)   # CIDR (IPv4 or IPv6)
            pfx="${t##*/}"
            case "$t" in
                *:*) echo 4294967295 ;;   # IPv6 CIDR: emit last
                *)
                    case "$pfx" in ''|*[!0-9]*) echo 4294967296; return ;; esac
                    { [ "$pfx" -ge 0 ] && [ "$pfx" -le 32 ]; } || { echo 4294967296; return; }
                    echo "$(( 1 << (32 - pfx) ))" ;;
            esac ;;
        *)     # single host (IPv4 or IPv6)
            echo 1 ;;
    esac
}

# -----------------------------------------------------------------------
# check_firewall_hook -- inject fw4 include once (idempotent)
# Ensures QoS rules survive every firewall reload.
# -----------------------------------------------------------------------
check_firewall_hook() {
    if ! uci show firewall | grep -q "path='/usr/bin/nft-limiter'"; then
        uci add firewall include >/dev/null
        uci set firewall.@include[-1].type='script'
        uci set firewall.@include[-1].path='/usr/bin/nft-limiter'
        uci set firewall.@include[-1].fw4_compatible='1'
        uci commit firewall
    fi
}

# -----------------------------------------------------------------------
# _rule_lines <idx> <target> <dl_kb> <ul_kb> <time_expr> <day_expr>
#   Outputs nftables rule lines (8-space indent) to stdout.
#   Uses global $_iface_set for interface scoping.
# -----------------------------------------------------------------------
_rule_lines() {
    local idx="$1" target="$2" dl_kb="$3" ul_kb="$4" time_expr="$5" day_expr="$6"
    local prefix=""
    [ -n "$time_expr" ] && prefix="${time_expr} "
    [ -n "$day_expr"  ] && prefix="${prefix}${day_expr} "

    local dl_match="meta iifname { ${_iface_set} } ip daddr $target"
    local ul_match="meta oifname { ${_iface_set} } ip saddr $target"

    if [ "$dl_kb" -gt 0 ] 2>/dev/null; then
        local dl_burst=$((dl_kb * 2))
        printf '        %s %scounter limit rate over %s kbytes/second burst %s kbytes drop comment "dev_%s_dl"\n' \
            "$dl_match" "$prefix" "$dl_kb" "$dl_burst" "$idx"
    fi
    printf '        %s %scounter accept comment "dev_%s_dl_pass"\n' "$dl_match" "$prefix" "$idx"
    if [ "$ul_kb" -gt 0 ] 2>/dev/null; then
        local ul_burst=$((ul_kb * 2))
        printf '        %s %scounter limit rate over %s kbytes/second burst %s kbytes drop comment "dev_%s_ul"\n' \
            "$ul_match" "$prefix" "$ul_kb" "$ul_burst" "$idx"
    fi
    printf '        %s %scounter accept comment "dev_%s_ul_pass"\n' "$ul_match" "$prefix" "$idx"
}

# -----------------------------------------------------------------------
# _catch_all_lines <dl_kb> <ul_kb> <time_expr> <day_expr>
#   Outputs catch-all rate limit rules for traffic not matched by any
#   per-device rule.  Uses global $_iface_set.  Must be appended LAST.
#   When time/day exprs are set, the catch-all only applies inside that
#   window; outside it, un-matched traffic is unrestricted.
# -----------------------------------------------------------------------
_catch_all_lines() {
    local dl_kb="$1" ul_kb="$2" time_expr="$3" day_expr="$4"
    local prefix=""
    [ -n "$time_expr" ] && prefix="${time_expr} "
    [ -n "$day_expr"  ] && prefix="${prefix}${day_expr} "

    if [ "$dl_kb" -gt 0 ] 2>/dev/null; then
        local dl_burst=$((dl_kb * 2))
        printf '        meta iifname { %s } %scounter limit rate over %s kbytes/second burst %s kbytes drop comment "default_dl"\n' \
            "$_iface_set" "$prefix" "$dl_kb" "$dl_burst"
    fi
    if [ "$ul_kb" -gt 0 ] 2>/dev/null; then
        local ul_burst=$((ul_kb * 2))
        printf '        meta oifname { %s } %scounter limit rate over %s kbytes/second burst %s kbytes drop comment "default_ul"\n' \
            "$_iface_set" "$prefix" "$ul_kb" "$ul_burst"
    fi
}

# -----------------------------------------------------------------------
# _time_and_day_expr <timestart> <timeend> <week>
#   Sets shell variables _time_expr and _day_expr for use in rules.
# -----------------------------------------------------------------------
_time_and_day_expr() {
    local ts="$1" te="$2" week="$3"
    _time_expr=""
    _day_expr=""

    if [ -n "$ts" ] && [ -n "$te" ]; then
        if [ "$ts" != "00:00" ] || [ "$te" != "00:00" ]; then
            _time_expr="meta hour \"${ts}\"-\"${te}\""
        fi
    fi

    if [ -n "$week" ] && [ "$week" != "0" ]; then
        local nft_days="" d nd
        for d in $(echo "$week" | tr ',' ' '); do
            [ "$d" -eq 7 ] && nd=0 || nd="$d"
            nft_days="${nft_days:+${nft_days}, }${nd}"
        done
        _day_expr="meta day { ${nft_days} }"
    fi
}

# -----------------------------------------------------------------------
# _collect_dev <cfg>  -- config_foreach callback; records "<addr_count> <idx>"
#   for each enabled device with a target into $_order_list. $_cfg_idx is
#   advanced for every device section (incl. disabled) so the recorded index
#   matches the UCI @device[idx] position (and the dev_<idx> rule comment).
# -----------------------------------------------------------------------
_collect_dev() {
    local cfg="$1" enable target
    config_get_bool enable "$cfg" enable 1
    if [ "$enable" -eq 0 ]; then
        _cfg_idx=$((_cfg_idx + 1))
        return 0
    fi
    config_get target "$cfg" target
    [ -n "$target" ] && \
        printf '%s\t%s\n' "$(_target_addr_count "$target")" "$_cfg_idx" >> "$_order_list"
    _cfg_idx=$((_cfg_idx + 1))
}

# -----------------------------------------------------------------------
# _emit_device <idx>  -- read UCI @device[idx] and print its rule lines to
#   stdout. Keeps dev_<idx> tied to the original section index.
# -----------------------------------------------------------------------
_emit_device() {
    local idx="$1"
    local target download upload timestart timeend week dl_kb ul_kb
    target=$(uci -q get "${NAME}.@device[${idx}].target")
    [ -z "$target" ] && return 0
    download=$(uci  -q get "${NAME}.@device[${idx}].download")
    upload=$(uci    -q get "${NAME}.@device[${idx}].upload")
    timestart=$(uci -q get "${NAME}.@device[${idx}].timestart")
    timeend=$(uci   -q get "${NAME}.@device[${idx}].timeend")
    week=$(uci      -q get "${NAME}.@device[${idx}].week")
    dl_kb=$(awk -v v="${download:-0}" 'BEGIN { printf "%.0f", v * 125 }')
    ul_kb=$(awk -v v="${upload:-0}"   'BEGIN { printf "%.0f", v * 125 }')
    _time_and_day_expr "$timestart" "$timeend" "$week"
    _rule_lines "$idx" "$target" "$dl_kb" "$ul_kb" "$_time_expr" "$_day_expr"
}

# -----------------------------------------------------------------------
# build_chain -- flush and rebuild the complete QoS chain from UCI config
# -----------------------------------------------------------------------
build_chain() {
    _cfg_idx=0
    config_load "$NAME"
    _build_iface_set

    {
        printf 'table inet %s {\n' "$NFT_TABLE"
        printf '    chain %s {\n' "$NFT_CHAIN"
        printf '        type filter hook forward priority filter - 5; policy accept;\n'
        printf '    }\n}\n\n'
        printf 'flush chain inet %s %s\n\n' "$NFT_TABLE" "$NFT_CHAIN"
        printf 'table inet %s {\n    chain %s {\n' "$NFT_TABLE" "$NFT_CHAIN"
    } > "$NFT_FILE"

    # Emit device rules most-specific-first (smallest address count) so a
    # per-host rule wins over a broader subnet/range that contains it. The
    # dev_<idx> comment keeps the original UCI section index so the Status
    # view's index mapping stays correct.
    _order_list="/tmp/nft-limiter-order.$$"
    : > "$_order_list"
    _cfg_idx=0
    config_foreach _collect_dev device
    if [ -s "$_order_list" ]; then
        sort -k1,1n -k2,2n "$_order_list" | while read -r _cnt _didx; do
            _emit_device "$_didx"
        done >> "$NFT_FILE"
    fi
    rm -f "$_order_list"

    local def_glimit def_sched def_dl def_ul def_dl_kb def_ul_kb def_ts def_te def_week
    def_glimit=$(uci -q get "${NAME}.@${NAME}[0].glimit")
    def_dl=$(uci -q get "${NAME}.@${NAME}[0].download")
    def_ul=$(uci -q get "${NAME}.@${NAME}[0].upload")
    def_dl_kb=$(awk -v v="${def_dl:-0}" 'BEGIN { printf "%.0f", v * 125 }')
    def_ul_kb=$(awk -v v="${def_ul:-0}" 'BEGIN { printf "%.0f", v * 125 }')
    # Absent flag is treated as enabled so upgrades keep existing global limits.
    [ "${def_glimit:-1}" = "1" ] || { def_dl_kb=0; def_ul_kb=0; }
    def_sched=$(uci -q get "${NAME}.@${NAME}[0].gschedule")
    def_ts=$(uci   -q get "${NAME}.@${NAME}[0].timestart")
    def_te=$(uci   -q get "${NAME}.@${NAME}[0].timeend")
    def_week=$(uci -q get "${NAME}.@${NAME}[0].week")
    # Absent flag is treated as enabled so upgrades keep an existing schedule.
    [ "${def_sched:-1}" = "1" ] || { def_ts="00:00"; def_te="00:00"; def_week="0"; }
    _time_and_day_expr "$def_ts" "$def_te" "$def_week"
    _catch_all_lines "$def_dl_kb" "$def_ul_kb" "$_time_expr" "$_day_expr" >> "$NFT_FILE"

    printf '    }\n}\n' >> "$NFT_FILE"
    nft -f "$NFT_FILE"
}

# -----------------------------------------------------------------------
# del_device_rules <idx> -- remove rules for device <idx> by nft handle
# -----------------------------------------------------------------------
del_device_rules() {
    local idx="$1" handle tag
    for tag in dl dl_pass ul ul_pass; do
        handle=$(nft -a list chain inet "${NFT_TABLE}" "${NFT_CHAIN}" 2>/dev/null \
            | grep "comment \"dev_${idx}_${tag}\"" \
            | grep -o 'handle [0-9]*' | awk '{print $2}')
        [ -n "$handle" ] && \
            nft delete rule inet "${NFT_TABLE}" "${NFT_CHAIN}" handle "$handle" 2>/dev/null
    done
}

# -----------------------------------------------------------------------
# add_device_rules <idx> -- read UCI for device <idx>, append its rules
# -----------------------------------------------------------------------
add_device_rules() {
    local idx="$1"
    del_device_rules "$idx"
    _build_iface_set

    local enable target download upload timestart timeend week
    enable=$(uci -q get "${NAME}.@device[${idx}].enable")
    [ "$enable" != "1" ] && return 0

    target=$(uci -q get "${NAME}.@device[${idx}].target")
    [ -z "$target" ] && return 0

    download=$(uci -q get "${NAME}.@device[${idx}].download" || echo "0")
    upload=$(uci    -q get "${NAME}.@device[${idx}].upload"  || echo "0")
    timestart=$(uci -q get "${NAME}.@device[${idx}].timestart")
    timeend=$(uci   -q get "${NAME}.@device[${idx}].timeend")
    week=$(uci      -q get "${NAME}.@device[${idx}].week")

    local dl_kb ul_kb
    dl_kb=$(awk -v v="${download:-0}" 'BEGIN { printf "%.0f", v * 125 }')
    ul_kb=$(awk -v v="${upload:-0}"   'BEGIN { printf "%.0f", v * 125 }')

    _time_and_day_expr "$timestart" "$timeend" "$week"

    local handle ctag
    for ctag in default_dl default_ul; do
        handle=$(nft -a list chain inet "${NFT_TABLE}" "${NFT_CHAIN}" 2>/dev/null \
            | grep "comment \"${ctag}\"" \
            | grep -o 'handle [0-9]*' | awk '{print $2}')
        [ -n "$handle" ] && \
            nft delete rule inet "${NFT_TABLE}" "${NFT_CHAIN}" handle "$handle" 2>/dev/null
    done

    # Preserve this device's expr before _time_and_day_expr is reused below.
    local dev_time_expr="$_time_expr" dev_day_expr="$_day_expr"

    local def_glimit def_sched def_dl def_ul def_dl_kb def_ul_kb def_ts def_te def_week
    def_glimit=$(uci -q get "${NAME}.@${NAME}[0].glimit")
    def_dl=$(uci -q get "${NAME}.@${NAME}[0].download")
    def_ul=$(uci -q get "${NAME}.@${NAME}[0].upload")
    def_dl_kb=$(awk -v v="${def_dl:-0}" 'BEGIN { printf "%.0f", v * 125 }')
    def_ul_kb=$(awk -v v="${def_ul:-0}" 'BEGIN { printf "%.0f", v * 125 }')
    # Absent flag is treated as enabled so upgrades keep existing global limits.
    [ "${def_glimit:-1}" = "1" ] || { def_dl_kb=0; def_ul_kb=0; }
    def_sched=$(uci -q get "${NAME}.@${NAME}[0].gschedule")
    def_ts=$(uci   -q get "${NAME}.@${NAME}[0].timestart")
    def_te=$(uci   -q get "${NAME}.@${NAME}[0].timeend")
    def_week=$(uci -q get "${NAME}.@${NAME}[0].week")
    # Absent flag is treated as enabled so upgrades keep an existing schedule.
    [ "${def_sched:-1}" = "1" ] || { def_ts="00:00"; def_te="00:00"; def_week="0"; }
    _time_and_day_expr "$def_ts" "$def_te" "$def_week"
    local def_time_expr="$_time_expr" def_day_expr="$_day_expr"

    local tmp="/tmp/nft-limiter_dev${idx}.nft"
    {
        printf 'table inet %s {\n    chain %s {\n' "$NFT_TABLE" "$NFT_CHAIN"
        _rule_lines "$idx" "$target" "$dl_kb" "$ul_kb" "$dev_time_expr" "$dev_day_expr"
        _catch_all_lines "$def_dl_kb" "$def_ul_kb" "$def_time_expr" "$def_day_expr"
        printf '    }\n}\n'
    } > "$tmp"
    nft -f "$tmp"
    rm -f "$tmp"
}

# -----------------------------------------------------------------------
# Main commands
# -----------------------------------------------------------------------
start() {
    local enabled
    enabled=$(uci -q get "${NAME}.@${NAME}[0].enabled")
    [ "$enabled" != "1" ] && return 0
    check_firewall_hook
    build_chain
}

stop() {
    nft delete chain inet "${NFT_TABLE}" "${NFT_CHAIN}" 2>/dev/null
    rm -f "$NFT_FILE"
}

status() {
    echo "=== nft-limiter status ==="
    printf 'Enabled : %s\n' "$(uci -q get "${NAME}.@${NAME}[0].enabled")"
    echo ""
    echo "=== ${NFT_CHAIN} chain ==="
    nft list chain inet "${NFT_TABLE}" "${NFT_CHAIN}" 2>/dev/null || echo "(chain not loaded)"
    echo ""
    echo "=== firewall4 hook ==="
    uci show firewall 2>/dev/null | grep -A4 "nft-limiter" || echo "(no firewall hook)"
}

case "$1" in
    start)  start ;;
    stop)   stop ;;
    add)    add_device_rules "$2" ;;
    del)    del_device_rules "$2" ;;
    status) status ;;
    *)      start ;;
esac
